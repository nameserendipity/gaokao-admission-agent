# Local-only server secrets. Copy this file to .env.local and fill real keys there.
# Do not commit .env.local. Configure the same names in Vercel Environment Variables.

# DeepSeek is optional. Without this key the app uses deterministic rule-based summaries and answers.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Tavily is optional. It is only used as a fallback when local SQLite evidence is insufficient.
TAVILY_API_KEY=
# TAVILY_API_URL=https://api.tavily.com/search

# Local admission database. Keep empty to use data/admission_clean.db.
ADMISSION_DB_PATH=

# Optional Postgres/Supabase for saved reports or future user data. Not required for the current SQLite knowledge-base MVP.
DATABASE_URL=
# POSTGRES_URL=
# SUPABASE_DB_URL=
DB_SSL=true

# Local server port used by src/server.ts
PORT=5000
